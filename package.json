{
  "name": "singular",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:ui": "npm run build:ui:ng && npm run build:ui:tailwind",
    "build:ui:ng": "ng build ui",
    "build:ui:tailwind": "npx @tailwindcss/cli -i projects/ui/src/lib/styles/index.css -o ./dist/ui/index.css --minify",
    "watch:ui": "npx concurrently \"npm run watch:ui:ng\" \"npm run watch:ui:tailwind\"",
    "watch:ui:ng": "ng build ui --watch",
    "watch:ui:tailwind": "npx @tailwindcss/cli -i projects/ui/src/lib/styles/index.css -o ./dist/ui/index.css --watch",
    "link:ui": "cd dist/ui && npm link && cd ../../ && npm link @singular/ui",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:docs": "node dist/docs/server/server.mjs"
  },
  "private": true,
  "packageManager": "npm@11.12.1",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-server": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.7",
    "@lucide/angular": "^1.8.0",
    "@singular/ui": "file:dist/ui",
    "express": "^5.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.0",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "jsdom": "^28.0.0",
    "ng-packagr": "^21.2.0",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
